APP_NAME=DHTC Platform
DEBUG=true
ENVIRONMENT=development

# Async driver: postgresql+asyncpg
DATABASE_URL=postgresql+asyncpg://dhtc:dhtc@localhost:5432/dhtc

JWT_SECRET=change_me_in_prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

CORS_ORIGINS=["http://localhost:3000"]

# Image upload (product images)
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=2097152

# Facebook OAuth Login (P5A) — placeholder, real values trong .env (KHÔNG commit)
FACEBOOK_APP_ID=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback
FRONTEND_URL=http://localhost:5173
