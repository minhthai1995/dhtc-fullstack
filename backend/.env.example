APP_NAME=DHTC Platform
DEBUG=true
ENVIRONMENT=development

# Async driver: postgresql+asyncpg
DATABASE_URL=postgresql+asyncpg://dhtc:dhtc@localhost:5432/dhtc

JWT_SECRET=change_me_in_prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

CORS_ORIGINS=["http://localhost:3000"]

# Image upload (product images)
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=2097152

# Facebook OAuth Login (P5A) — placeholder, real values trong .env (KHÔNG commit)
FACEBOOK_APP_ID=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback
FRONTEND_URL=http://localhost:5173

# Facebook Messenger / Page (P5C-enrich + P5E) — secrets stay in .env only
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=dhtc_webhook_2026
FACEBOOK_GRAPH_API_VERSION=v22.0
MESSENGER_PROFILE_CACHE_DAYS=30

# Proactive reply (P5E) — go-live AFTER Meta App Review approves
# pages_manage_engagement + pages_read_user_content.
PROACTIVE_REPLY_ENABLED=false
PROACTIVE_REPLY_DRY_RUN=true
PROACTIVE_REPLY_RATE_LIMIT_PER_HOUR=30
PROACTIVE_REPLY_PER_PSID_COOLDOWN_HOURS=24
